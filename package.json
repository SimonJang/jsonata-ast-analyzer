{
  "name": "jsonata-ast-analyzer",
  "version": "1.0.0",
  "description": "Static analysis of JSONata expressions to extract data paths",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "jsonata-paths": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "bench": "pnpm build && node scripts/benchmark.mjs",
    "release:check": "pnpm typecheck && pnpm build && pnpm test && node scripts/benchmark.mjs",
    "test": "vitest run",
    "test:corpus": "vitest run test/corpus/jsonata-corpus.test.ts",
    "test:unit": "vitest run --exclude 'test/integration/**'",
    "test:integration": "vitest run test/integration/",
    "test:watch": "vitest",
    "test:update-snapshots": "vitest run --update",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "jsonata": "2.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
